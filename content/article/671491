  function _isLogin() {
    Ls.www.memberLoginCheck(function (data, options) {
      if (data.isLogin) {
        // 已登录
        var member = data.curMember;
        $('#c_title').val(member.name).attr('readonly', true).addClass('readonly');
      } else {
        // 未登录
        alert(options.text);
        location.href = data.redirectUrl;
      }
    });
  }
