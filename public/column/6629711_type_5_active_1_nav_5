            var urlQueryName = Ls.url.get("queryName");
    var urlQueryCode = Ls.url.get("queryCode");
    if (urlQueryCode !='' && urlQueryCode!=''){
        $("#queryName").val(urlQueryName)
        $("#queryCode").val(urlQueryCode)
    }
    var pagePublicApply = function () {
        var cur = {
            params: {
                siteId: "4697420",
                organId: "6629711",
                pageIndex: 0,
                pageSize: "15"
            },
            queryParams: function () {
                return {
                    queryNameVal: $.trim($("#queryName").val()),
                    queryCodeVal: $.trim($("#queryCode").val())
                }
            }
        }

        var _fn = function () {
            var me = this;
            me.siteId = '4697420';
            me.form$ = $('#apply_query_form');
            me.applyType$ = $('.public-apply-type');
            me.queryList$ = $("#public_apply_query_list");
            me.queryDetail$ = $("#public_apply_query_detail");
            me.init();
        }

        _fn.prototype.bind = function () {
            var me = this;
            $(document).on('click', '.show-apply-detail', function () {
                var this$ = $(this),
                    data = this$.data();
                if (data && data.id) {
                    cur.showType = 0;
                    me.queryId(data.id);
                }
            }).on('click', '.back-public-query-list', function () {
                cur.showType = 1;
                me.changeShowType();
            });
            return me;
        }

        _fn.prototype.changeShowType = function () {
            var me = this;
            me.applyType$.addClass('hide');
            if (cur.showType == 1) {
                me.queryList$.removeClass('hide');
            } else {
                me.queryDetail$.removeClass('hide');
            }
            return me;
        }

        _fn.prototype.validator = function () {
            var me = this;
            using("validator", function () {
                me.form$.validator({
                    fields: {
                        'queryName': '申请人/单位名称:required;',
                        'queryCode': '申请单编号:required;',
                    },
                    valid: function (form) {
                        me.queryByCode();
                    }
                });
            });
            return me;
        }

        _fn.prototype.queryId = function (queryId) {
            var me = this;
            Ls.ajax({
                url: "/public/applyDetail?id=" + queryId
            }).done(function (d) {
                me.changeShowType();
                me.queryDetail$.html(Ls.template("public_apply_query_detail_tpl", d.data));
            });
            return me;
        }

        _fn.prototype.applyQueryPagination = function (pageIndex, pageCount) {
            var me = this;
            Ls.pagination("#public_apply_query_pageination", function (pageIndex) {
                cur.params.queryCode = "";
                cur.params.queryPassword = "";
                cur.params.pageIndex = pageIndex - 1;
                me.applyQuery(cur.params);
            }, {
                currPage: (pageIndex + 1),
                pageCount: pageCount,
                param: "pageSize=15"
            });
            return me;
        }

        _fn.prototype.applyQuery = function () {
            var me = this;
            // 提交
            Ls.ajax({
                url: "/public/applyQuery",
                data: cur.params
            }).done(function (d) {
                if (d.status == 1) {
                    var pageCount = d.data.pageCount;
                    var pageIndex = d.data.pageIndex;
                    if (pageCount == 0) {
                        $("#public_apply_query_content_ul").html("");
                    } else {
                        var content = Ls.template("public_apply_query_tpl", d.data);
                        $("#public_apply_query_content_ul").html(content);
                        if (pageCount > 1) {
                            $("#public_apply_query_pageination").show();
                            me.applyQueryPagination(pageIndex, pageCount);
                        }
                    }
                } else {
                    // 返回错误信息
                    Ls.tipsErr(d.desc);
                }
            });
            return me;
        }

        _fn.prototype.queryByCode = function () {
            var me = this,
                p = cur.queryParams();

            if (p.queryNameVal == "") {
                Ls.tipsErr("名称不能为空!");
                return;
            }

            if (p.queryCodeVal == "") {
                Ls.tipsErr("申请单号不能为空!");
                return;
            }

            Ls.ajax({
                dataType: "html",
                url: "/site/label/8888",
                type: "post",
                data: {
                    labelName: "publicNewApplyDetail",
                    name: p.queryNameVal,
                    code: p.queryCodeVal,
                    siteId: me.siteId,
                    isJson: true
                }
            }).done(function (res) {
                debugger;
                res = Ls.parseEval(res);
                if (res && res.publicApplyEO) {
                    var publicApplyEO = res.publicApplyEO,
