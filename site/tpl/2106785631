  <script type="text/javascript">
   var globl_organId = '';
    var global_catId = "";
    var global_divId = '';
    var global_page_size = 15;

    $(function(){
        global_organId = "3722307";
        global_catId = "3684528";
        global_divId = "publicInfoListDiv";

        $("#" + global_organId).addClass("active");
        $("#" + global_catId).addClass("active");
        $("#" + global_divId).addClass("active");
        // 加载左侧党委、部门、乡镇、人大、其他列表
        loadOrganList(4,'dwList');
        loadOrganList(2,'zfList');
        loadOrganList(5,'rdList');
        loadOrganList(3,'xzList');
        loadOrganList(6,'qtList');
        loadOrganList(7,'xxList');
        

    })

    function loadOrganList(type,divId) {
        Ls.ajax({
            dataType: "html",
            data: {
                types: type,
                specialCode:'CZZJ_01',
                siteId: "4697420"
            },
            url: "/public/specialCatalog"
        }).done(function (d) {
		    if(type == 2){
               d = d.replaceAll('经信局','工信局');
			   d = d.replaceAll('退役军人厅','退役军人事务局');
            }
            $("#" + divId).html(d);
            console.log(d);
            if (type == 7) {
                // 加载默认目录数据，这里默认加载第一个党委的第一个目录
                $("#xxList li:first a").trigger('click');
            }
            $('#zfList li').each(function (i,el) {
                if($.trim($(el).text())==='扶贫开发局'){
                    $(el).remove()
                }
            })

        });
    }

    /**
     * 改变单位时重新加载右侧目录分类
     */
    function changeUnit(organId, configId,obj) {
        $("a[name='units']").each(function () {
            $(this).removeClass("active");
        });
        $(obj).addClass("active");
        global_organId = organId;

        Ls.ajax({
            dataType: "html",
            data: {
                id: configId,
                siteId: "4697420"
            },
            url: "/public/specialCatalog/list"
        }).done(function (d) {
            console.log("11111111111111111111");
            console.log(d);
            $("#catDiv2 ul").html(d);

            // 触发第一个目录
            $("#catDiv2 ul li:first a").trigger('click');
            $("#catalogs li").css("width","280px");
        });
    }

    function changeCatalog(catId) {
        loadPublicDatas(global_organId, catId, global_divId);
    }

    function changeCatalog(catId) {
        $("#catDiv2 a[name='catalog']").removeClass("active");
        $("#catDiv2 a[catId='" + catId + "']").addClass("active");
        loadPublicDatas(global_organId, catId, global_divId);
    }

    function loadPublicDatas(organId, catId, global_divId) {
        Ls.ajax({
            dataType: "html",
            data: {
                labelName:"publicInfoList",
                pageSize: global_page_size,
                pageIndex: 1,
                action: "list",
                isDate: "true",
                dateFormat: "yyyy-MM-dd",
                length: "37",
                organId: organId,
                catId: catId,
                type: 4,
                siteId: "4697420",
                result: "暂无相关信息",
                publicDivId: global_divId,
                file: "/c2/lingbi/publicInfoList-lb-03"
            },
            url: "/site/label/8888"
        }).done(function (d) {
            $("#" + global_divId).html(d);
        });
    }

    function changeCatalog(catId) {
        $("a[name='catalog']").each(function () {
            $(this).removeClass("active");
        });
        $("#" + catId).addClass("active");

        if (catId == "" && global_catId == "") {
            catId = 3685264;//行政权力 catId
            global_catId = catId;
        } else if (catId == "" && global_catId != "") {
            catId = global_catId;
        } else {
            global_catId = catId;
        }
        loadPublicDatas(global_organId, catId,global_divId);
    }

    function changeOrganRel(type, defaultOrganId) {
        if (defaultOrganId != null && defaultOrganId != "") {
            global_organId = defaultOrganId;
        }
        $("a[name='units']").each(function () {
            $(this).removeClass("active");
        });

        $("#catDiv2").removeAttr("style").addClass("qly_fltop");

        if (type == 4) {//党委及其他部门
            $("#dwList li:first a").addClass('active').trigger('click');
        }else if (type == 2) {//政府部门
            $("#zfList li:first a").addClass('active').trigger('click');
        }else if (type == 5) {//人大
            $("#rdList li:first a").addClass('active').trigger('click');
        } else if (type == 3) {//乡镇
            $("#xzList li:first a").addClass('active').trigger('click');
        } else if (type == 6){
            $("#qtList li:first a").addClass('active').trigger('click');
        } else if (type == 7){
            $("#xxList li:first a").addClass('active').trigger('click');
        }
    }
  </script>
